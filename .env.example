# ────────────────────────────────────────────────
# Copy file này → .env.local rồi điền giá trị thật
# ────────────────────────────────────────────────

# ── REMOTE (production) ─────────────────────────
# Lấy tại: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role key (chỉ dùng phía server, KHÔNG expose ra client)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── LOCAL (dev — uncomment để dùng) ─────────────
# Boot bằng: npx supabase start
# Lấy keys bằng: npx supabase status
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# ── ADMIN AUTH ──────────────────────────────────
# Comma-separated email allowlist for /admin access.
# Tài khoản phải tồn tại trong Supabase Auth (tạo qua Studio: Auth → Users).
# Để trống = bất kỳ user đã đăng nhập nào cũng có quyền admin (KHÔNG khuyến khích).
ADMIN_EMAILS=admin@example.com
